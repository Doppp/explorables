{
  "name": "explorables",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.15.1",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "build": "pnpm build:packages && pnpm course:build && pnpm minimal:build && pnpm site:build",
    "build:packages": "tsx scripts/build-packages.ts",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm course:validate",
    "course": "tsx packages/cli/src/bin.ts start examples/ai-from-first-principles",
    "course:build": "tsx packages/cli/src/bin.ts build examples/ai-from-first-principles",
    "course:test": "tsx packages/cli/src/bin.ts test examples/ai-from-first-principles",
    "course:validate": "tsx packages/cli/src/bin.ts validate examples/ai-from-first-principles && tsx packages/cli/src/bin.ts validate examples/minimal-course",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "minimal:build": "tsx packages/cli/src/bin.ts build examples/minimal-course",
    "site:build": "vite build --config apps/site/vite.config.ts",
    "site:dev": "vite --config apps/site/vite.config.ts",
    "site:test": "playwright test --config apps/site/playwright.config.ts",
    "test": "vitest run",
    "test:browser": "playwright test",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "commander": "latest",
    "esbuild": "0.28.1",
    "gray-matter": "latest",
    "hast-util-to-html": "latest",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "rehype-sanitize": "6.0.0",
    "rehype-stringify": "latest",
    "remark-directive": "4.0.0",
    "remark-frontmatter": "latest",
    "remark-parse": "11.0.0",
    "remark-rehype": "latest",
    "unified": "11.0.5",
    "unist-util-visit": "latest",
    "vite": "8.1.5",
    "yaml": "latest",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@explorables/cli": "workspace:*",
    "@axe-core/playwright": "latest",
    "@biomejs/biome": "2.5.5",
    "@playwright/test": "1.61.1",
    "@testing-library/dom": "latest",
    "@testing-library/react": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "axe-core": "latest",
    "jsdom": "latest",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
